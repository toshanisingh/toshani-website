# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Database (Neon Postgres) ---------------------------------------------
# Create a free project at https://neon.tech, then from the dashboard copy:
#  - the POOLED connection string (host contains "-pooler") -> DATABASE_URL
#  - the DIRECT connection string (no "-pooler")            -> DIRECT_URL
# Both should include `?sslmode=require`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# --- Admin login -----------------------------------------------------------
# The single admin account is bound to this email (hardcoded default:
# toshani.s333@gmail.com). The password is set by the admin via the first-time
# setup / forgot-password flow and stored in the database — not here.
# ADMIN_EMAIL="toshani.s333@gmail.com"

# Session-signing secret. Also signs password setup/reset links.
# Generate with:  npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=""

# --- Email (Resend) — sends the password setup / reset link ----------------
# Sign up at https://resend.com with the admin Gmail; create an API key.
# Without this, the reset link is logged to the server console (dev only).
RESEND_API_KEY=""
# Optional. Defaults to Resend's shared sender; works for emailing your own
# account address in test mode without verifying a domain.
# EMAIL_FROM="Toshani <onboarding@resend.dev>"

# Trusted site origin used to build password reset links. REQUIRED in
# production — reset links are NOT derived from request headers there (that
# would allow reset-link poisoning). AUTH_URL is also read if set.
# APP_URL="https://your-site.vercel.app"
# AUTH_URL="https://your-site.vercel.app"
