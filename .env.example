# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Database (Neon Postgres) ---------------------------------------------
# Create a free project at https://neon.tech, then from the dashboard copy:
#  - the POOLED connection string (host contains "-pooler") -> DATABASE_URL
#  - the DIRECT connection string (no "-pooler")            -> DIRECT_URL
# Both should include `?sslmode=require`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# --- Admin login -----------------------------------------------------------
# The single admin account. Login is checked against these (no DB needed).
ADMIN_EMAIL="you@example.com"
# Generate with:  node scripts/hash-password.mjs 'your-password'
ADMIN_PASSWORD_HASH=""
# Session-signing secret. Generate with:  npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=""
